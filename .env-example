# Flask / General
FLASK_SECRET_KEY=change-me
SESSION_TYPE=filesystem
NGROK_URL=https://example.ngrok-free.app
DEBUG=False
LOG_PATH=app.log
PORT=5001
DATABASE_NAME=conversations.db

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ROOT_PHONE_NUMBER=+15551234567

# Ngrok (for docker-compose auto-tunnel)
NGROK_AUTHTOKEN=your-ngrok-authtoken

# OpenAI / AI Providers
OPENAI_KEY=sk-xxxx
ANTHROPIC_KEY=sk-ant-xxxx
AGENT_NAME=Prax
BASE_MODEL=gpt-4o
LLM_PROVIDER=openai
AGENT_TEMPERATURE=0.7
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Flight Search (Amadeus API — free tier at https://developers.amadeus.com)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Search / External APIs
GOOGLE_API_KEY=AIzaSy...
GOOGLE_CSE_ID=custom-search-id
GOOGLE_VERTEX_PROJECT=my-project
GOOGLE_VERTEX_LOCATION=us-central1
NYT_USERNAME=user@example.com
NYT_PASSWORD=password

# Discord (free alternative to Twilio — set token to enable)
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS={"123456789012345678": "Alice"}
DISCORD_ALLOWED_CHANNELS=
# Link Discord users to phone numbers to share conversation history + workspace.
# Use your PERSONAL phone number (from PHONE_TO_NAME_MAP), NOT the Twilio ROOT_PHONE_NUMBER.
DISCORD_TO_PHONE_MAP={"123456789012345678": "+15551234567"}

# Workspace (git-backed per-user document storage)
WORKSPACE_DIR=./workspaces

# Browser (persistent profiles let Prax stay logged in to sites like x.com)
# By default, browser profiles are stored inside each user's workspace
# ({WORKSPACE_DIR}/{user_id}/.browser_profile/). Set BROWSER_PROFILE_DIR
# below to override with a shared location.
#BROWSER_PROFILE_DIR=./browser_profiles
#BROWSER_HEADLESS=true
#BROWSER_TIMEOUT=30000
#SITES_CREDENTIALS_PATH=./sites.yaml

# Prax SSH Key — lets Prax push workspaces to a private remote
# 1. Generate a key:  ssh-keygen -t ed25519 -f ~/.ssh/prax_deploy_key -N "" -C "prax-workspace"
# 2. Add ~/.ssh/prax_deploy_key.pub as a deploy key with WRITE access on your repo
#    (GitHub: Settings → Deploy keys → Add deploy key)
# 3. Base64-encode the private key:  cat ~/.ssh/prax_deploy_key | base64 | tr -d '\n'
# 4. Paste the output below
PRAX_SSH_KEY_B64=

# Phone metadata (JSON strings)
PHONE_TO_NAME_MAP='{"+15551234567": "Example User"}'
PHONE_TO_EMAIL_MAP='{"+15551234567": "user@example.com"}'
PHONE_TO_GREETING_MAP='{"+15551234567": "greeting_example.mp3"}'
