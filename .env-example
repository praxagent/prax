# Flask / General
FLASK_SECRET_KEY=change-me
SESSION_TYPE=filesystem
NGROK_URL=https://example.ngrok-free.app
DEBUG=False
LOG_PATH=app.log
# Web-search backend. 'legacy' = the sunset duckduckgo-search package (prior
# behaviour; its backends have been observed hanging). RECOMMENDED: 'ddgs' —
# the actively-maintained successor, no API key, titled+linked snippets.
SEARCH_PROVIDER=ddgs
# SEARCH_MAX_RESULTS=6
# Wall-clock timeout (seconds) for the web-search tool. The DuckDuckGo search
# backends occasionally hang instead of erroring, which parks a whole turn
# indefinitely. Recommended: 60. 0 (default) = no timeout (prior behavior).
# WEB_SEARCH_TIMEOUT_S=60
# Runtime location for the metacognitive learned-state store. Defaults to a
# gitignored runtime/ subdir of the shipped seed profiles, so live learning
# never dirties the tracked seeds. Set to relocate it (e.g. a mounted volume).
# METACOGNITIVE_DIR=
PORT=5001
# Interface Prax binds. Default 127.0.0.1 (loopback only) — secure by default: a
# host install isn't network-reachable; a same-host reverse proxy (tailscale
# serve / nginx / Caddy) still reaches it via localhost. Set 0.0.0.0 ONLY behind
# an authenticating proxy + firewall (see docs/security/network-exposure.md).
# The container image already sets this to 0.0.0.0 (its boundary is the published
# port). TeamWork has the matching TEAMWORK_HOST knob.
# PRAX_HOST=127.0.0.1
DATABASE_NAME=conversations.db

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ROOT_PHONE_NUMBER=+15551234567

# Ngrok (for docker-compose auto-tunnel — Twilio voice/SMS only)
# Twilio's servers must reach Prax's webhook routes from the public
# internet, so the ngrok tunnel stays scoped to that flow.  Course/note
# publishing and per-file sharing now ride on Tailscale (see below) or
# the gated /shared/<token> route.
NGROK_AUTHTOKEN=your-ngrok-authtoken

# ── Tailscale sidecar (optional, recommended for remote access) ───────
# Runs `tailscaled` inside Docker so your server's host network never has
# to expose Prax — your laptop reaches the stack over the tailnet only.
#
# 1. Get a key from https://login.tailscale.com/admin/settings/keys
#    Pick: Reusable ✓, Ephemeral ✗, Pre-approved ✓
#    (Ephemeral keys count against the free tier's 1,000-min/month minute
#    budget — non-ephemeral keys do not.)
# 2. Uncomment both lines below.
# 3. `docker compose up -d` — sidecar starts automatically.
#
# Without COMPOSE_PROFILES=tailscale the sidecar is silently skipped, so
# leaving these commented is the same as not having it.
#TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx
#TS_HOSTNAME=prax
#COMPOSE_PROFILES=tailscale
#TS_EXTRA_ARGS=--accept-dns=false

# ── Sandbox (coding/browser/desktop environment — the prax-sandbox repo) ──
# Master switch. Leave true (default) for the full experience. Set false to
# run Prax as a pure harness with NO sandbox tools, spokes, or container
# dependency. The sandbox itself lives in the sibling prax-sandbox repo.
#SANDBOX_ENABLED=true
#
# REMOTE sandbox (optional): leave SANDBOX_DAEMON_URL empty to use a local
# in-process sandbox. Set it to drive a sandbox on another box via the
# control daemon (TLS + bearer). See ../prax-sandbox/docs/remote.md.
#SANDBOX_DAEMON_URL=https://sandbox-host:8843
#SANDBOX_DAEMON_TOKEN=
#SANDBOX_TLS_VERIFY=true              # true | false | path to a CA bundle
#SANDBOX_CLIENT_CERT=                 # opt-in mTLS
#SANDBOX_CLIENT_KEY=

# OpenAI / AI Providers
OPENAI_KEY=sk-xxxx
ANTHROPIC_KEY=sk-ant-xxxx
AGENT_NAME=Prax
LLM_PROVIDER=openai
AGENT_TEMPERATURE=0.7
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model Tiers — provider-agnostic intelligence levels.
# Prax defaults to LOW and upgrades when needed.  Set *_ENABLED=false to disable a tier.
# For Anthropic: LOW=haiku, MEDIUM=sonnet, HIGH=opus, PRO=opus
# For local/vllm: set all to your local model name
BASE_MODEL=gpt-5.4-nano
LOW_MODEL=gpt-5.4-nano
LOW_ENABLED=true
MEDIUM_MODEL=gpt-5.4-mini
MEDIUM_ENABLED=true
HIGH_MODEL=gpt-5.5
HIGH_ENABLED=true
PRO_MODEL=gpt-5.5-pro
PRO_ENABLED=true

# Per-component tier/model/provider overrides (optional).
# These override the defaults in prax/plugins/configs/llm_routing.yaml
# without touching any config files — useful for per-deployment tuning.
# Convention: {COMPONENT}_{KEY} in UPPER_CASE.
# Examples:
#   ORCHESTRATOR_TIER=high           # upgrade the main agent loop
#   SUBAGENT_RESEARCH_TIER=medium    # downgrade research to save cost
#   SUBAGENT_BROWSER_PROVIDER=anthropic  # use Claude for browser spoke
#   ORCHESTRATOR_TEMPERATURE=0.5     # lower creativity for the main loop
# Available components: orchestrator, subagent_research, subagent_knowledge,
#   subagent_browser, subagent_course, subagent_sandbox, subagent_sysadmin,
#   subagent_finetune, subagent_memory, subagent_workspace, subagent_scheduler
# Available keys: TIER, MODEL, PROVIDER, TEMPERATURE

# Vision / Image Understanding
# Provider-agnostic: set VISION_PROVIDER to openai, anthropic, or google.
# The model is passed to that provider's API and must be a vision-capable CHAT
# model — image-GENERATION models (gpt-image-*) 500 on analysis calls. Examples:
#   OpenAI:    gpt-5.4-mini
#   Anthropic: claude-sonnet-4-20250514 (or any vision-capable Claude model)
#   Google:    gemini-2.0-flash
VISION_MODEL=gpt-5.4-mini
# Image GENERATION model (distinct from VISION_MODEL analysis) — builtin generate_image + Library covers
IMAGE_MODEL=gpt-image-1
VISION_PROVIDER=openai

# Local vision model (optional) — point analyze_image at any
# OpenAI-compatible server (llama.cpp llama-server, vLLM, Ollama, LM Studio).
# When VISION_BASE_URL is set, Prax inlines images as base64 data URIs so the
# local server doesn't need outbound network access to the Discord/Twilio CDN.
# VISION_API_KEY is optional — most local servers ignore it.
# Example (llama.cpp llama-server with --alias qwen-vl):
#   VISION_PROVIDER=openai
#   VISION_MODEL=qwen-vl
#   VISION_BASE_URL=http://localhost:8083/v1
# VISION_BASE_URL=
# VISION_API_KEY=

# ── Local / self-hosted LLM (optional; GPU NOT required) ────────────────────
# Point the chat/orchestrator LLM at any local or cloud OpenAI-compatible server
# (ds4 / llama.cpp / vLLM / Ollama). The `vllm` provider is just an OpenAI client
# against VLLM_BASE_URL — it needs no API key. GPU is optional: a high-RAM CPU box
# running a MoE model (few active params/token) is the cheap path for overnight
# evals. See docs/guides/local-cpu-inference.md (CPU/Mac/Spark sizing + engine
# setup), docs/guides/cloud-gpu.md, docs/guides/local-vision.md, and the eval
# overnight workflow in prax/eval/README.md.
#
# Example — antirez's ds4 (DeepSeek V4) serving its OpenAI-compatible endpoint:
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=http://<ds4-host>:<port>/v1
# LOW_MODEL=deepseek-v4-flash
# MEDIUM_MODEL=deepseek-v4-flash
# HIGH_MODEL=deepseek-v4-flash
#
# Example — vLLM / Ollama / llama.cpp on a CPU box (MoE = fast on CPU):
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=http://localhost:8000/v1
# LOCAL_MODEL=Qwen/Qwen3-8B
# For a SOVEREIGN / on-prem / EU-AI-Act deployment, serve an open model here —
# recommended: Apertus (https://apertvs.ai/, EU-compliant). Tool-calling fidelity
# on open backends is tracked, not assumed — IDEAS_BACKLOG #20.
# Fine-tuning (LoRA via Unsloth; GPU required). See docs/guides/local-vision.md.
# FINETUNE_ENABLED=false
# FINETUNE_BASE_MODEL=unsloth/Qwen3-8B-unsloth-bnb-4bit
# FINETUNE_OUTPUT_DIR=./adapters
# FINETUNE_MAX_STEPS=60
# FINETUNE_LEARNING_RATE=2e-4
# FINETUNE_LORA_RANK=16
# Cloud GPU power control (optional; the `gpu_power` plugin + examples/gpu-power-broker/).
# Least-privilege "on/off only": Prax holds ONLY a bearer token to a user-run
# power-broker, never a broad cloud cred. Unset GPU_POWER_BROKER_URL ⇒ the plugin
# registers no tools (fail-closed). See docs/guides/cloud-gpu.md + IDEAS_BACKLOG #16.
# GPU_PROVIDER=            # none | broker | aws | gcp
# GPU_POWER_BROKER_URL=
# GPU_POWER_BROKER_TOKEN=
# GPU_INSTANCE_ID=

# Auto-generate cover images for new spaces (uses OPENAI_KEY).
# Set to false to disable — spaces will use gradient placeholders instead.
AUTO_GENERATE_COVER=true

# Flight Search (Amadeus API — free tier at https://developers.amadeus.com)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Jina AI Reader (https://jina.ai) — used by fetch_url_content,
# note_from_url, and SMS/Discord URL auto-capture for clean HTML→markdown
# extraction.  Works without a key on the free tier (lower rate limits,
# ~20 req/min).  Set this to upgrade to paid quota for higher throughput.
JINA_API_KEY=

# X / Twitter API v2 bearer token.  When set, x.com/twitter.com STATUS links are
# fetched via the API instead of the web reader (X locked down scraping, so the
# reader/browser path fails on tweets).
TWITTER_API=

# Enhanced tweet fetching: expand t.co links to real URLs and fetch the
# author's full self-thread (root + self-replies, in posting order) when the
# linked tweet is part of one.  Costs 1–2 extra API calls per tweet fetch and
# needs an X API tier with /2/tweets/search/recent access (Basic and up).  The
# search window is 7 days — older threads degrade to the single linked tweet.
# Only genuine self-threads are expanded (never another author's posts).
TWITTER_THREAD_FETCH=false

# Label fetch_url_content results with their true provenance: posts fetched via
# a platform's native API (X / Bluesky / Threads) get a SOCIAL POST tag — the
# text/links/handles/metrics are verbatim from the API, while claims inside the
# post stay the author's own (NOT verified) — plus a "(fetched via ...)" suffix,
# instead of being mislabeled as scraped web content.
URL_FETCH_SOURCE_TAGS=false

# Threads (Meta) Graph API access token.  threads.net post links are fetched via
# graph.threads.net.  Reading third-party public posts requires an app with
# Advanced Access for threads_basic; otherwise it falls back to the web reader.
THREADS_API=
# (Bluesky needs NO key — bsky.app posts use the open public AppView API.)

# Search / External APIs
GOOGLE_API_KEY=AIzaSy...
GOOGLE_CSE_ID=custom-search-id
GOOGLE_VERTEX_PROJECT=my-project
GOOGLE_VERTEX_LOCATION=us-central1
NYT_USERNAME=user@example.com
NYT_PASSWORD=password

# Discord (free alternative to Twilio — set token to enable)
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS={"123456789012345678": "Alice"}
DISCORD_ALLOWED_CHANNELS=
# Link Discord users to phone numbers to share conversation history + workspace.
# Use your PERSONAL phone number (from PHONE_TO_NAME_MAP), NOT the Twilio ROOT_PHONE_NUMBER.
DISCORD_TO_PHONE_MAP={"123456789012345678": "+15551234567"}

# Agent Autonomy Level
# guided     = current behavior, prescriptive workflow rules, all safety gates
# balanced   = removes prescriptive workflow rules, agent uses judgment
# autonomous = also relaxes recursion limits, lets agent self-upgrade tier,
#              earned trust can downgrade browser tool risk levels
PRAX_AUTONOMY=balanced

# Workspace (git-backed per-user document storage)
# Default: ../workspaces (outside repo root to prevent accidental secret commits)
WORKSPACE_DIR=../workspaces

# User identity — REQUIRED for Docker deployments.
# The sandbox mounts only this user's workspace folder for isolation.
# Pick any slug (e.g. usr_alice, myworkspace). Prax will refuse to start
# without this when running in Docker.
# All sandbox-persistent data (browser profiles, desktop settings, coding
# agent configs) is stored inside {WORKSPACE_DIR}/{PRAX_USER_ID}/.sandbox/.
PRAX_USER_ID=

# Browser (persistent profiles let Prax stay logged in to sites like x.com)
# By default, browser profiles are stored inside each user's workspace
# ({WORKSPACE_DIR}/{user_id}/.browser_profile/). Set BROWSER_PROFILE_DIR
# below to override with a shared location.
#BROWSER_PROFILE_DIR=./browser_profiles
#BROWSER_HEADLESS=true
#BROWSER_TIMEOUT=30000
#SITES_CREDENTIALS_PATH=./sites.yaml
# CDP endpoint — Playwright connects to this Chrome instead of launching its own.
# In docker-compose this is set automatically to the sandbox Chrome.
# Leave empty for local dev (Playwright will launch a standalone browser).
# Host-process deployments (make run-local-all): use the published loopback
# port instead: BROWSER_CDP_URL=http://localhost:9223
#BROWSER_CDP_URL=http://sandbox:9223

# Sandbox-only browsing: never run a Chromium on the harness host — keep the
# host dedicated to orchestration (browser rendering stays in the sandbox
# container).  When the sandbox Chrome is unreachable, browser tools report it
# as down instead of falling back to a locally-launched browser, and manual
# logins route to the TeamWork Browser panel instead of a host Xvfb/x11vnc
# session.  Requires BROWSER_CDP_URL to point at the sandbox CDP port.
BROWSER_SANDBOX_ONLY=false

# Prax SSH Key — lets Prax push workspaces to a private remote
# Preferred: bind-mount the key file read-only (see README for docker-compose example)
# Fallback: base64-encode and paste below (env vars can leak in crash dumps, APM traces, etc.)
# 1. Generate a key:  ssh-keygen -t ed25519 -f ~/.ssh/prax_deploy_key -N "" -C "prax-workspace"
# 2. Add ~/.ssh/prax_deploy_key.pub as a deploy key with WRITE access on your repo
#    (GitHub: Settings → Deploy keys → Add deploy key)
# 3. Base64-encode the private key:  cat ~/.ssh/prax_deploy_key | base64 | tr -d '\n'
# 4. Paste the output below
PRAX_SSH_KEY_B64=

# Self-Improvement — global gate for all self-modification capabilities.
# When enabled, Prax can modify his own code via PRs, use coding agents
# in the sandbox for collaborative development, and deploy hot-fixes.
# When disabled, all self-modification tools are hidden from the agent.
SELF_IMPROVE_ENABLED=false
# Preferred coding agent for self-improvement tasks in the sandbox.
# Options: claude-code (Anthropic), codex (OpenAI), opencode (open-source).
# All three are installed in the sandbox container.
# WARNING: All three use provider API tokens and cost money per invocation.
# Monitor your API spend when self-improvement is enabled.
# To configure each agent, open TeamWork's terminal tab and run:
#   Claude Code:  claude login          (or set ANTHROPIC_API_KEY in .env)
#   Codex:        codex login           (or set OPENAI_API_KEY / OPENAI_KEY in .env)
#   OpenCode:     opencode              (interactive setup on first run)
# Config is persisted across container restarts via Docker volumes.
SELF_IMPROVE_AGENT=claude-code

# Memory System (vector store + knowledge graph for long-term memory)
# Qdrant and Neo4j run as first-class services in docker-compose — always on.
# Set to false to disable memory even when the services are available.
MEMORY_ENABLED=true
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=prax-memory
# Embedding model — used for semantic memory search
#EMBEDDING_PROVIDER=openai
#EMBEDDING_MODEL=text-embedding-3-small

# Embedding provider — used for semantic memory search.
# Default: OpenAI (cheapest option, ~$0.02/M tokens, no extra RAM).
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# For local embeddings with Ollama (no data sent to OpenAI, but ~1.5GB extra RAM):
#   docker compose --profile local-llm up
#   EMBEDDING_PROVIDER=ollama
#   EMBEDDING_MODEL=nomic-embed-text
#   OLLAMA_BASE_URL=http://ollama:11434
#
# For fully local (fastembed, in-process, no external service):
#   EMBEDDING_PROVIDER=local
OLLAMA_BASE_URL=http://localhost:11434
# Consolidation interval in seconds (3600 = hourly)
MEMORY_CONSOLIDATION_INTERVAL=3600
# Ebbinghaus decay half-life in days (memories lose half their importance)
MEMORY_DECAY_HALFLIFE_DAYS=7.0
# Max STM entries before LLM compaction triggers
MEMORY_STM_MAX_ENTRIES=50

# Observability (OTel tracing, Prometheus metrics, Grafana dashboards)
# Set to true and start the observability profile to get the full stack:
#   docker compose --profile observability up
# Prax safely degrades if the profile isn't active (no OOM, no retries).
OBSERVABILITY_ENABLED=true
GRAFANA_URL=http://localhost:3002

# Health Monitoring Watchdog
# Periodic self-checks every N turns — detects tool error spikes, context
# overflows, latency degradation, spoke failures, and recent code changes.
# Disable for minimal RAM / lightweight deployments.
HEALTH_MONITOR_ENABLED=true

# TeamWork (web UI — Slack-like interface for Prax)
# Disabled by default for standalone use (uv run python app.py).
# Docker Compose sets this to true automatically.
TEAMWORK_ENABLED=false
# Set TEAMWORK_PATH to the teamwork repo if it's not at ../teamwork
#TEAMWORK_PATH=../teamwork
# Optional API key for external agent access (empty = no auth required in dev)
TEAMWORK_API_KEY=
# User-facing base URL for course/note links Prax surfaces in chat.
# Defaults to the local Docker port mapping (works for localhost + SSH tunnel).
# You usually DON'T need to set this: when it's unset/localhost, Prax
# auto-derives the public URL from the live deployment (Tailscale MagicDNS /
# ngrok), so links work off-network without editing .env.  Set it explicitly
# only to force a specific URL (an explicit non-local value always wins).
#TEAMWORK_BASE_URL=http://localhost:8000
# Auto-derive the public base URL for links from Tailscale/ngrok (default true).
# Set false for strict config-only behaviour (use TEAMWORK_BASE_URL verbatim).
#PUBLIC_URL_AUTODETECT=true

# Phone metadata (JSON strings)
PHONE_TO_NAME_MAP='{"+15551234567": "Example User"}'
PHONE_TO_EMAIL_MAP='{"+15551234567": "user@example.com"}'
PHONE_TO_GREETING_MAP='{"+15551234567": "greeting_example.mp3"}'

BROWSER_VNC_ENABLED=true

# ─────────────────────────────────────────────────────────────────────
# Reliability & quality (2026-06) — flag-gated; code defaults are OFF so the
# harness behaves exactly as before unless you opt in.  The values below are
# the RECOMMENDED configuration per the first eval-gate run (2026-07-08, every
# flag A/B'd against baseline — verdicts, method, and caveats in
# docs/research/flag-eval-campaign-2026-07-08.md; flag rationale in
# docs/research/reliable-agentic-systems-bayer.md).
# ─────────────────────────────────────────────────────────────────────

# Cross-provider LLM failover: on a provider-side failure (rate limit,
# overload, connection error, OPEN breaker) transparently retry on another
# provider instead of surfacing the error.  Chain auto-derives from
# configured providers if LLM_FALLBACK_CHAIN is empty.
LLM_FALLBACK_ENABLED=false
#LLM_FALLBACK_CHAIN=anthropic:claude-sonnet-4-20250514,google:gemini-2.5-pro
# When failover is on, a *terminal* provider failure (auth / billing / access /
# decommissioned — which a retry won't fix) denylists that provider from the
# pool and tells the user the likely cause (e.g. a late bill or revoked key),
# instead of re-hitting it every turn.  Re-probed after the cooldown (0 = until
# restart).  No effect when LLM_FALLBACK_ENABLED is off.
LLM_PROVIDER_DENYLIST_ENABLED=true
#LLM_PROVIDER_DENYLIST_COOLDOWN_SECONDS=1800

# Inject the structured failure diagnosis back into the retry so the model
# re-plans with it in context (on by default — error-path only).
RECOVERY_CONTEXT_INJECTION=true

# Durable checkpoints (resume a crashed/timed-out turn across restarts) +
# user-initiated resume of a failed turn (skips completed steps).
CHECKPOINT_BACKEND=memory          # or: sqlite (durable — needed for resume across restart)
#CHECKPOINT_DB_PATH=.prax/checkpoints.sqlite
CHECKPOINT_RESUME_ENABLED=false
#CHECKPOINT_RESUME_TTL=3600
# Resumable-pointer state file (only used when resume is enabled). To discard
# all pending resumes: delete this file, or set CHECKPOINT_RESUME_ENABLED=false.
#CHECKPOINT_RESUME_STATE_PATH=.prax/resumable.json

# Continuous evaluation: nightly reference-free scoring of sampled traces →
# Prometheus (prax_eval_quality).  `make eval` runs the regression gate.
EVAL_NIGHTLY_ENABLED=false
#EVAL_NIGHTLY_SAMPLE_SIZE=25
#EVAL_NIGHTLY_CRON=0 4 * * *

# Benchmark suites (make eval-capability / eval-harness-lift / eval-gaia).
# PRAX_EVAL_DIR auto-defaults to a repo-sibling `prax-evals/` (override to relocate
# the isolated, out-of-repo run data). PRAX_EVAL_TASK_TIMEOUT_S=0 means NO per-task
# wall-clock kill — the right default for a slow local model run overnight; set a
# positive value only as a safety rail. USD rates default to 0 (a local model has
# no per-token cost; runs are ranked by tokens + wall-time).
#PRAX_EVAL_DIR=/abs/path/to/prax-evals
#PRAX_EVAL_TASK_TIMEOUT_S=0
#PRAX_EVAL_CONCURRENCY=1
#PRAX_EVAL_USD_IN_PER_1M=0
#PRAX_EVAL_USD_OUT_PER_1M=0
# Self-regeneration loop (#29): `make eval-self-regen` proposes a system-prompt
# overlay, verifies it against the capability suite, keeps iff it improves AND the
# anti-spike overseer approves. Propose-only by default; set this true + pass
# APPLY=1 to let it auto-apply the winner (graded autonomy). Verifier + overseer
# always live outside the editable surface.
SELF_REGEN_ENABLED=false

# Retrieval precision: paraphrase/HyDE query expansion + LLM-judge rerank (memory),
# plus hybrid vector+keyword knowledge-graph concept search (default ON; degrades
# to substring when Qdrant is unavailable). Backfill old concepts with
# knowledge_graph.reindex_user_concepts(user_id).
# Eval gate 2026-07-08: DEFERRED — the capability suite has too little
# retrieval coverage to measure lift, and these add LLM calls per query;
# needs a purpose-built retrieval eval before recommending.
RETRIEVAL_QUERY_EXPANSION=false
#RETRIEVAL_QUERY_EXPANSION_N=3
RETRIEVAL_RERANK=false
#RETRIEVAL_RERANK_CANDIDATES=20
KNOWLEDGE_HYBRID_ENABLED=true

# Context engineering: shrink the base system prompt on simple turns +
# a cheap pre-flight clarifying-question gate for ambiguous/risky requests.
# Eval gate 2026-07-08: selectivity FLIPPED ON (no regression, ~2% fewer
# tokens); intent clarification measured +11% tokens with NO pass-rate gain —
# leave off unless your traffic is ambiguity-heavy.
PROMPT_SELECTIVITY_ENABLED=true
INTENT_CLARIFICATION_ENABLED=false

# Tool boundaries + transparency: deny-by-default risk for unrecognised
# tools; scope a HIGH-risk confirmation to just the confirmed tool; surface
# claim-audit warnings on attended replies (not only the Auditor channel).
# Eval gate 2026-07-08: deny-by-default REGRESSED correctness (blocked a
# needed tool; a capability case failed) — keep off until tuned. Attended
# quarantine: capability-clean but its sycophancy A/B was inconclusive.
UNKNOWN_TOOL_HIGH_RISK=false
HIGH_RISK_SCOPED_CONFIRM=false
CLAIM_AUDIT_ATTENDED_QUARANTINE=false
# Lethal-trifecta guard: once a turn ingests UNTRUSTED content + reads PRIVATE
# data, escalate EXTERNAL-SINK tools to HIGH (confirmation) — the architectural
# defense against indirect prompt-injection exfiltration. Default off.
LETHAL_TRIFECTA_GUARD=false
# In-loop agent middleware (prax/agent/loop_middleware.py): provenance-taint
# untrusted-source tool results INSIDE the loop before they re-enter the
# model's context, and touch the trace heartbeat on every model step — the
# in-loop counterpart to the perimeter governance wrapper.
# Eval gate 2026-07-08: FLIPPED ON — no capability regression, ~7% fewer
# tokens, injection defense-in-depth (measured security lift was within
# noise at the small sample; the flip rests on no-regression + cost).
AGENT_MIDDLEWARE_ENABLED=true

# SSRF egress guard (default ON): blocks outbound HTTP from the plugin gateway
# and URL reader to private/loopback/link-local hosts + the cloud metadata
# endpoint (169.254.169.254). Add dev hosts to the allowlist if you self-host a
# service the agent should reach (e.g. a local Qdrant). See docs/security/.
SSRF_PROTECTION_ENABLED=true
#SSRF_ALLOWED_HOSTS=localhost,127.0.0.1

# MCP server (default OFF): expose a curated, bearer-gated subset of Prax tools
# to OTHER agents over the Model Context Protocol (POST /mcp). Fail-closed — the
# endpoint only mounts when at least one client is configured. HIGH-risk tools
# are never exposed. See docs/infrastructure/mcp-server.md.
MCP_SERVER_ENABLED=false
# Single-caller shortcut: one token → one identity → MCP_TOOL_ALLOWLIST (or the
# read-only default set).
#MCP_BEARER_TOKEN=
#MCP_USER_ID=
#MCP_TOOL_ALLOWLIST=get_current_datetime,memory_recall,knowledge_search
# Per-caller registry: each token maps to its own user_id + tool allowlist (this
# is how you grant write tools to a specific trusted caller). JSON:
# {"clients":[{"name","token"|"token_sha256","user_id","allow":[...]|"default",
#  "expires_at":"2026-12-31T00:00:00Z"}]}  (expires_at optional)
#MCP_CLIENTS_PATH=/secrets/mcp_clients.json
# Token expiry (default OFF): when on, enforce the optional per-client
# "expires_at" (ISO-8601) above, plus MCP_TOKEN_EXPIRES_AT for the single-token
# client. Expired tokens are rejected exactly like invalid ones. Issue
# short-lived tokens to other agents and let them lapse instead of rotating.
#MCP_TOKEN_EXPIRY_ENABLED=false
#MCP_TOKEN_EXPIRES_AT=2026-12-31T00:00:00Z

# Public share-link TTL (default OFF): when on, every new public share
# (workspace_share_file + course/note publish) gets an expiry stamped at
# creation and 404s once past it (purged from the registry on the next listing).
# Re-publishing a course/note renews its lease. Shares created while OFF have no
# expiry and live until explicitly revoked.
#SHARE_LINK_TTL_ENABLED=false
#SHARE_LINK_TTL_SECONDS=604800   # 7 days

AUTO_TIER_ESCALATION=true
