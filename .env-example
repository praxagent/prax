# Flask / General
FLASK_SECRET_KEY=change-me
SESSION_TYPE=filesystem
NGROK_URL=https://example.ngrok-free.app
DEBUG=False
LOG_PATH=app.log
PORT=5001
DATABASE_NAME=conversations.db

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ROOT_PHONE_NUMBER=+15551234567

# Ngrok (for docker-compose auto-tunnel)
NGROK_AUTHTOKEN=your-ngrok-authtoken

# OpenAI / AI Providers
OPENAI_KEY=sk-xxxx
ANTHROPIC_KEY=sk-ant-xxxx
AGENT_NAME=Prax
BASE_MODEL=gpt-5.4-nano
LLM_PROVIDER=openai
AGENT_TEMPERATURE=0.7
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model Tiers — provider-agnostic intelligence levels.
# Prax defaults to LOW and upgrades when needed.  Set *_ENABLED=false to disable a tier.
# For Anthropic: LOW=haiku, MEDIUM=sonnet, HIGH=opus, PRO=opus
# For local/vllm: set all to your local model name
LOW_MODEL=gpt-5.4-nano
LOW_ENABLED=true
MEDIUM_MODEL=gpt-5.4-mini
MEDIUM_ENABLED=true
HIGH_MODEL=gpt-5.4
HIGH_ENABLED=true
PRO_MODEL=gpt-5.4-pro
PRO_ENABLED=false

# Vision / Image Understanding
# Provider-agnostic: set VISION_PROVIDER to openai, anthropic, or google.
# The model is passed to that provider's API. Examples:
#   OpenAI:    gpt-image-1.5
#   Anthropic: claude-sonnet-4-20250514 (or any vision-capable Claude model)
#   Google:    gemini-2.0-flash
VISION_MODEL=gpt-image-1.5
VISION_PROVIDER=openai

# Flight Search (Amadeus API — free tier at https://developers.amadeus.com)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# Search / External APIs
GOOGLE_API_KEY=AIzaSy...
GOOGLE_CSE_ID=custom-search-id
GOOGLE_VERTEX_PROJECT=my-project
GOOGLE_VERTEX_LOCATION=us-central1
NYT_USERNAME=user@example.com
NYT_PASSWORD=password

# Discord (free alternative to Twilio — set token to enable)
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS={"123456789012345678": "Alice"}
DISCORD_ALLOWED_CHANNELS=
# Link Discord users to phone numbers to share conversation history + workspace.
# Use your PERSONAL phone number (from PHONE_TO_NAME_MAP), NOT the Twilio ROOT_PHONE_NUMBER.
DISCORD_TO_PHONE_MAP={"123456789012345678": "+15551234567"}

# Agent Autonomy Level
# guided     = current behavior, prescriptive workflow rules, all safety gates
# balanced   = removes prescriptive workflow rules, agent uses judgment
# autonomous = also relaxes recursion limits, lets agent self-upgrade tier,
#              earned trust can downgrade browser tool risk levels
PRAX_AUTONOMY=balanced

# Workspace (git-backed per-user document storage)
WORKSPACE_DIR=./workspaces

# Browser (persistent profiles let Prax stay logged in to sites like x.com)
# By default, browser profiles are stored inside each user's workspace
# ({WORKSPACE_DIR}/{user_id}/.browser_profile/). Set BROWSER_PROFILE_DIR
# below to override with a shared location.
#BROWSER_PROFILE_DIR=./browser_profiles
#BROWSER_HEADLESS=true
#BROWSER_TIMEOUT=30000
#SITES_CREDENTIALS_PATH=./sites.yaml
# CDP endpoint — Playwright connects to this Chrome instead of launching its own.
# In docker-compose this is set automatically to the sandbox Chrome.
# Leave empty for local dev (Playwright will launch a standalone browser).
#BROWSER_CDP_URL=http://sandbox:9223

# Prax SSH Key — lets Prax push workspaces to a private remote
# Preferred: bind-mount the key file read-only (see README for docker-compose example)
# Fallback: base64-encode and paste below (env vars can leak in crash dumps, APM traces, etc.)
# 1. Generate a key:  ssh-keygen -t ed25519 -f ~/.ssh/prax_deploy_key -N "" -C "prax-workspace"
# 2. Add ~/.ssh/prax_deploy_key.pub as a deploy key with WRITE access on your repo
#    (GitHub: Settings → Deploy keys → Add deploy key)
# 3. Base64-encode the private key:  cat ~/.ssh/prax_deploy_key | base64 | tr -d '\n'
# 4. Paste the output below
PRAX_SSH_KEY_B64=

# Observability (OTel tracing, Prometheus metrics, Grafana dashboards)
# Enabled automatically in docker-compose.dev.yml. Leave false for prod unless
# you have an external Tempo/Prometheus/Loki deployment.
OBSERVABILITY_ENABLED=false
GRAFANA_URL=http://localhost:3001

# TeamWork (web UI — Slack-like interface for Prax)
# Set TEAMWORK_PATH to the teamwork repo if it's not at ../teamwork
#TEAMWORK_PATH=../teamwork
# Optional API key for external agent access (empty = no auth required in dev)
TEAMWORK_API_KEY=

# Phone metadata (JSON strings)
PHONE_TO_NAME_MAP='{"+15551234567": "Example User"}'
PHONE_TO_EMAIL_MAP='{"+15551234567": "user@example.com"}'
PHONE_TO_GREETING_MAP='{"+15551234567": "greeting_example.mp3"}'
