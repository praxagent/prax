# ─────────────────────────────────────────────────────────────────────────
# secrets-proxy environment  →  copy to `.env-proxy` (gitignored) and fill in.
#
# This file is loaded ONLY by the secrets proxy (`make secrets-proxy` /
# `python -m prax.secrets_proxy`). It is the ONE place the REAL API keys live.
# Prax itself uses a SEPARATE `.env` with only placeholder keys — so a
# compromised/injected Prax has nothing to steal. See docs/security/secrets-proxy.md.
# NEVER commit `.env-proxy` (it's gitignored).
# ─────────────────────────────────────────────────────────────────────────

# The REAL model-provider keys (only the proxy holds these).
OPENAI_KEY=sk-real-openai-key-here
ANTHROPIC_KEY=sk-ant-real-anthropic-key-here

# Where the proxy listens (Prax points OPENAI_BASE_URL/ANTHROPIC_BASE_URL here).
# It is UNAUTHENTICATED by design — bind loopback (or a private net only the
# keyless Prax can reach); reachability is the control, like the sandbox ports.
PROXY_HOST=127.0.0.1
PROXY_PORT=8785

# Optional: route the OpenAI-compatible leg at a third-party (OpenRouter/DeepSeek)
# instead of api.openai.com. The Anthropic leg defaults to api.anthropic.com.
# PROXY_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# PROXY_ANTHROPIC_BASE_URL=https://api.anthropic.com
# PROXY_ANTHROPIC_VERSION=2023-06-01

# Optional: write an audit line per proxied call (method/provider/path/status/size
# — NEVER the key or body) to this file, for after-the-fact review.
# PROXY_AUDIT_LOG=/var/log/prax-secrets-proxy.log

# Optional: whole-request timeout (seconds) and a different env file to load.
# PROXY_TIMEOUT_S=600
# PROXY_ENV_FILE=.env-proxy
