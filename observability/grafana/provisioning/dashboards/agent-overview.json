{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Spoke Delegations / minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(prax_spoke_calls_total[1m])) by (spoke)",
          "legendFormat": "{{spoke}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      }
    },
    {
      "title": "Spoke Duration (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(prax_spoke_duration_seconds_bucket[5m])) by (le, spoke))",
          "legendFormat": "p50 {{spoke}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(prax_spoke_duration_seconds_bucket[5m])) by (le, spoke))",
          "legendFormat": "p95 {{spoke}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "Spoke Success vs Failure",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(prax_spoke_calls_total{status=\"success\"}) by (spoke)",
          "legendFormat": "{{spoke}} OK"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(prax_spoke_calls_total{status!=\"success\"}) by (spoke)",
          "legendFormat": "{{spoke}} FAIL"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Delegation Tree (Traces)",
      "type": "traces",
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "nativeSearch",
          "serviceName": "prax",
          "spanName": "prax.orchestrator.orchestrator",
          "limit": 10
        }
      ]
    },
    {
      "title": "Top Tools by Invocation Count",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(15, sum(prax_tool_calls_total) by (tool))",
          "legendFormat": "{{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 },
              { "color": "yellow", "value": 100 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Logs (errors + warnings)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=~\"/prax-prax-.*\"} |~ \"(ERROR|WARNING|FAIL|error|fail)\"",
          "legendFormat": ""
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["prax", "agents", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Prax - Agent Overview",
  "uid": "prax-agent-overview"
}
